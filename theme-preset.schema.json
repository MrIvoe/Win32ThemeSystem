{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/theme-preset.schema.json",
  "title": "Win32ThemeStudio Theme Preset",
  "type": "object",
  "required": [
    "formatVersion",
    "theme",
    "paletteValues"
  ],
  "properties": {
    "formatVersion": {
      "type": "string",
      "const": "1.0"
    },
    "theme": {
      "type": "object",
      "required": [
        "id",
        "displayName",
        "appearance",
        "category",
        "accentFamily",
        "description",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "appearance": {
          "type": "string",
          "enum": ["light", "dark"]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "accentFamily": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "sourceThemeUri": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["solid", "gradient", "image"]
        },
        "primaryColor": {
          "type": "string",
          "pattern": "^#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
        },
        "secondaryColor": {
          "type": "string",
          "pattern": "^#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
        },
        "imageUri": {
          "type": "string",
          "minLength": 1
        },
        "sizingMode": {
          "type": "string",
          "enum": ["fill", "fit", "stretch", "tile", "center"]
        },
        "tintColor": {
          "type": "string",
          "pattern": "^#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
        },
        "opacity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "blurEnabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "paletteValues": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
      }
    }
  },
  "additionalProperties": false
}
