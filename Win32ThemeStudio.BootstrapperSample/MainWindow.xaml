<Window x:Class="Win32ThemeStudio.BootstrapperSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win32 Theme Bootstrapper Sample"
    Height="840"
    Width="1280"
        MinHeight="640"
    MinWidth="1100">
    <DockPanel Background="{DynamicResource Brush.Background}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Sample">
                <MenuItem Header="Bootstrapper" />
                <MenuItem Header="Theme Metadata" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Third-Party Host" />
            </MenuItem>
        </Menu>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Bootstrapper Sample"
                                   FontSize="24"
                                   FontWeight="Bold" />
                        <TextBlock Text="This host app references the theme library like a third-party consumer, filters metadata, and round-trips presets through JSON."
                                   Margin="0,4,0,14"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />

                        <TextBlock Text="Appearance" FontWeight="SemiBold" />
                        <ComboBox x:Name="AppearanceComboBox"
                                  Margin="0,6,0,10"
                                  SelectionChanged="AppearanceComboBox_SelectionChanged" />

                        <TextBlock Text="Category" FontWeight="SemiBold" />
                        <ComboBox x:Name="CategoryComboBox"
                                  Margin="0,6,0,10"
                                  SelectionChanged="CategoryComboBox_SelectionChanged" />

                        <TextBlock Text="Accent Family" FontWeight="SemiBold" />
                        <ComboBox x:Name="AccentFamilyComboBox"
                                  Margin="0,6,0,10"
                                  SelectionChanged="AccentFamilyComboBox_SelectionChanged" />

                        <TextBlock Text="Theme" FontWeight="SemiBold" />
                        <ComboBox x:Name="ThemeComboBox"
                                  Margin="0,6,0,12"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="ThemeComboBox_SelectionChanged" />

                        <TextBlock Text="Metadata" FontWeight="SemiBold" />
                        <TextBlock x:Name="ThemeSummaryTextBlock"
                                   Margin="0,6,0,6"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                        <TextBlock x:Name="ThemeDescriptionTextBlock"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Tags" FontWeight="SemiBold" />
                        <ListBox x:Name="TagsListBox" Margin="0,6,0,12" Height="110" />

                        <TextBlock Text="Preset Source" FontWeight="SemiBold" />
                        <TextBlock x:Name="PresetSourceTextBlock"
                                   Margin="0,6,0,10"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />

                        <TextBlock Text="Preset JSON" FontWeight="SemiBold" />
                        <TextBox x:Name="PresetJsonTextBox"
                                 Margin="0,6,0,10"
                                 Height="250"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />

                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="Export Theme JSON"
                                Style="{StaticResource AccentButton}"
                                    Click="ExportThemeJsonButton_Click" />
                            <Button Content="Apply JSON Preset"
                                Style="{StaticResource SuccessButton}"
                                    Click="ApplyJsonPresetButton_Click" />
                            <Button Content="Load Sample Preset File"
                                Style="{StaticResource WarningButton}"
                                    Click="LoadSamplePresetButton_Click" />
                        </WrapPanel>

                        <TextBlock x:Name="PresetPathTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Third-Party App Preview"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="The host app filters themes with ThemeCatalog metadata and swaps palettes via ThemeManager."
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Operations Panel" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="Representative business controls rendered by an external app importing the package."
                                           Margin="0,4,0,10"
                                           Foreground="{DynamicResource Brush.TextSecondary}" />

                                <WrapPanel>
                                    <Button Content="Queue Task" Style="{StaticResource AccentButton}" />
                                    <Button Content="Run Report" Style="{StaticResource SuccessButton}" />
                                    <Button Content="Alert" Style="{StaticResource DangerButton}" />
                                </WrapPanel>

                                <TextBlock Text="Operator Note" FontWeight="SemiBold" Margin="0,10,0,4" />
                                <TextBox Text="Use metadata filters to present only dark terminal or retro themes to the user." />

                                <TextBlock Text="Job Completion" FontWeight="SemiBold" Margin="0,10,0,4" />
                                <ProgressBar Height="14" Value="68" Margin="0,0,0,6" />
                                <ProgressBar Height="14" Value="91" Foreground="{DynamicResource Brush.Success}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Bootstrap And Validation" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Text="ThemeManager.InitializeApplicationTheme(this, ThemeCatalog.DefaultDarkTheme);" />
                                <Separator Margin="0,10,0,10" />
                                <TextBlock Text="Active Filter Result" FontWeight="SemiBold" />
                                <TextBlock x:Name="FilterResultTextBlock"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.TextSecondary}" />
                                <Separator Margin="0,10,0,10" />
                                <TextBlock Text="Contrast Validation" FontWeight="SemiBold" />
                                <TextBlock x:Name="ContrastSummaryTextBlock"
                                           Margin="0,6,0,8"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource Brush.TextSecondary}" />
                                <ListBox x:Name="ContrastWarningsListBox" Height="240" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>