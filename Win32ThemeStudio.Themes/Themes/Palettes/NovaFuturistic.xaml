<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Nova Futuristic</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF3FBFF" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6F8FDFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFE6F6FF" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCEFFAFF" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66DFF6FF" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF13202E" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF3A5A73" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF00B4D8" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF009FC2" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF007EA0" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFACDCEE" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFF6FDFF" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFECF8FF" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFD7EEFB" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFDD2E44" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF1A936F" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#22000000" />
</ResourceDictionary>



