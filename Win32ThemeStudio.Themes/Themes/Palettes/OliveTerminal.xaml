<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Olive Terminal</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF151813" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E621261D" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF1B2118" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC181C15" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#6621261D" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF0F2DE" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFB2BA90" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF92B24A" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF809E3F" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF627A2D" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF39432C" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF1A1F17" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF171C15" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF252D20" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFFF7E6B" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF78BC61" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#66000000" />
</ResourceDictionary>