    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF1D2217" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF293020" />
    <SolidColorBrush x:Key="Brush.DisabledSurface" Color="#FF22271B" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFBE7561" />
    <SolidColorBrush x:Key="Brush.DangerForeground" Color="#FF231610" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFC8B25F" />
    <SolidColorBrush x:Key="Brush.WarningForeground" Color="#FF1F200F" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF7FAA5A" />
    <SolidColorBrush x:Key="Brush.SuccessForeground" Color="#FF14180F" />
