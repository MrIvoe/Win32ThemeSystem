<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Olive Terminal</sys:String>
    <sys:String x:Key="Theme.Id">olive-terminal</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF14170F" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF1E2418" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF283021" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC1A1F15" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66283021" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFE3EBC5" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFA9B188" />
    <SolidColorBrush x:Key="Brush.TextDisabled" Color="#FF7C8565" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF8BAA47" />
    <SolidColorBrush x:Key="Brush.AccentSecondary" Color="#FFB6C46A" />
    <SolidColorBrush x:Key="Brush.AccentTertiary" Color="#FF6D7454" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFA0B95A" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF728B39" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FF16190F" />
    <SolidColorBrush x:Key="Brush.SelectionFill" Color="#40B6C46A" />
