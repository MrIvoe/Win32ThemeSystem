<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Amber Terminal</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF191411" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6261D18" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF241A15" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC1F1814" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66261D18" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFFFF1D5" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFD1B783" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFF4A340" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFE38E27" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFBF6F0F" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF4A3525" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF201713" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF1D1612" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF2E221A" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFFF7B63" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF7EBF68" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#70000000" />
</ResourceDictionary>