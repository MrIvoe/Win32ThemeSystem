<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Amber Terminal</sys:String>
    <sys:String x:Key="Theme.Id">amber-terminal</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF14110D" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF201A14" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF2A221A" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC1A1612" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#662A221A" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFFFE7B3" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFC4A76D" />
    <SolidColorBrush x:Key="Brush.TextDisabled" Color="#FF8B7448" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFFFB000" />
    <SolidColorBrush x:Key="Brush.AccentSecondary" Color="#FFFFD36A" />
    <SolidColorBrush x:Key="Brush.AccentTertiary" Color="#FF8F6A25" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFFFC54A" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFD18A00" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FF241C14" />
    <SolidColorBrush x:Key="Brush.SelectionFill" Color="#40FFD36A" />
    <SolidColorBrush x:Key="Brush.FocusStroke" Color="#FFFFD36A" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF5A4320" />
    <SolidColorBrush x:Key="Brush.ScrollbarThumb" Color="#FF7A5C2D" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF241D17" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF1F1914" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF2E251C" />
    <SolidColorBrush x:Key="Brush.DisabledSurface" Color="#FF241F1A" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFFF7A59" />
    <SolidColorBrush x:Key="Brush.DangerForeground" Color="#FF2A1A14" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FFFFB000" />
    <SolidColorBrush x:Key="Brush.WarningForeground" Color="#FF241C14" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FFA6D66A" />
    <SolidColorBrush x:Key="Brush.SuccessForeground" Color="#FF1E2414" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#420F0A05" />
