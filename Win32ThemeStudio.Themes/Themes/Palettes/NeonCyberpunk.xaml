<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Neon Cyberpunk</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF0A0014" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E61A0B2C" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF25133D" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC10031F" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66281347" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF7F5FF" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFBFAEEB" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFFF2BD6" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFFF0FB8" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFE000A0" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF5D2B87" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF1B0A2E" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF160826" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF301250" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFFF4D6D" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF00F5D4" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#AA000000" />
</ResourceDictionary>



