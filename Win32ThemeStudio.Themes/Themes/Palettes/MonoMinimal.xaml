<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Mono Minimal</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6FFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFE6E6E6" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCF4F4F4" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF5A5A5A" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF444444" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF2F2F2F" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF151515" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFB7B7B7" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFF7F7F7" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFEDEDED" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFD8D8D8" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FF7A2E2E" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF2E6A44" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#26000000" />
</ResourceDictionary>



