<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Harbor Blue</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF2F6FA" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6FBFDFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFE7EEF5" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCDFEBF6" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#88F6FBFF" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF1B2B3A" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF587087" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF2D6FA3" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF245E8C" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF1B486A" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFB7CADC" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFF9FBFD" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFF1F6FA" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFDCE7F3" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFC24747" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF2E8B6A" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#29000000" />
</ResourceDictionary>