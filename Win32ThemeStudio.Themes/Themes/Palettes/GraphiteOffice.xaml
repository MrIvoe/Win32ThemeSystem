<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Graphite Office</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF13171C" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6202630" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF1C232D" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC171D26" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66202630" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF0F3F8" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFA7B0BC" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF5A8DEE" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF4A7DDD" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF3867B5" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF313A46" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF181E27" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF161B22" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF242D39" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFFF7A70" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF59B88C" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#66000000" />
</ResourceDictionary>