<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Ivory Bureau</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF8F6F0" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6FFFEFB" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF3EEE3" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCECE5D8" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#88FFFDF7" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF29231C" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF6F6659" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF6B7D9A" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF596C88" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF445468" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD8CFBF" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFFFFCF8" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFF7F3EA" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFEBE3D5" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFBC5A45" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF5B8A62" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#25000000" />
</ResourceDictionary>