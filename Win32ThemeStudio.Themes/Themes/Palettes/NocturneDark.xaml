    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF98A4B0" />
    <SolidColorBrush x:Key="Brush.TextDisabled" Color="#FF6F7C88" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF6E8FB7" />
    <SolidColorBrush x:Key="Brush.AccentSecondary" Color="#FF8F7CB6" />
    <SolidColorBrush x:Key="Brush.AccentTertiary" Color="#FFA6B5C7" />
