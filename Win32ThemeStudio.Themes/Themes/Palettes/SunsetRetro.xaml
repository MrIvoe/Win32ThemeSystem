<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Sunset Retro</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFFFE9D6" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6FFF4E8" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFFFDFC3" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCFFE9D6" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#66FFF8EA" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF3B2A1A" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF7C5939" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFF07167" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFE75B52" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFC5443D" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFFFC79A" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFFFF2E3" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFFFEBD7" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFFFD4B0" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFC0392B" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF2E8B57" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#30000000" />
</ResourceDictionary>



