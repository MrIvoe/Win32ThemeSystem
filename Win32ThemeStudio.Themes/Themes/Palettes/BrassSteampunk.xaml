<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Brass Steampunk</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FF211A14" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6332B23" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF3A2F24" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CC2A1F17" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#664A3B2E" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FFF5E9D8" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FFD8BDA0" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFB5843F" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFCC9951" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF94662A" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FF70563C" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FF2E241D" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FF281F19" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FF4A392C" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFD66A4E" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FFC6A15B" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#77000000" />
</ResourceDictionary>



