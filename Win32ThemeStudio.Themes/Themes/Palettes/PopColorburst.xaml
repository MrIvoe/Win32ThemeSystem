    <SolidColorBrush x:Key="Brush.TextDisabled" Color="#FF9BA1A9" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFFF6B6B" />
    <SolidColorBrush x:Key="Brush.AccentSecondary" Color="#FFFFD166" />
