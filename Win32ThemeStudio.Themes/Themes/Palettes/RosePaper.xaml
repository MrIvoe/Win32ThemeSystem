<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Theme.IsPalette">True</sys:String>
    <sys:String x:Key="Theme.DisplayName">Rose Paper</sys:String>
    <SolidColorBrush x:Key="Brush.Background" Color="#FFFBF4F5" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#E6FFFDFD" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF8E9EB" />
    <SolidColorBrush x:Key="Brush.WindowGlass" Color="#CCEFDCE0" />
    <SolidColorBrush x:Key="Brush.TransparentLayer" Color="#88FFF6F7" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF352228" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF7C5B65" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFC45A7A" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFAD4B6A" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF8A3653" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFE2C2CB" />
    <SolidColorBrush x:Key="Brush.TooltipBackground" Color="#FFFFFCFC" />
    <SolidColorBrush x:Key="Brush.MenuBackground" Color="#FFFCF4F6" />
    <SolidColorBrush x:Key="Brush.MenuHover" Color="#FFF4DFE4" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#FFC14D4D" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF4A9360" />
    <SolidColorBrush x:Key="Brush.Shadow" Color="#26000000" />
</ResourceDictionary>