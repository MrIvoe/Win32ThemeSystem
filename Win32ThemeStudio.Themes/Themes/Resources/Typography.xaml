<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window Base Style -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Brush.WindowGlass}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- TextBlock Base Style -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

</ResourceDictionary>
