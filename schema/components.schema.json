{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/components.schema.json",
  "title": "Universal Component Tokens",
  "description": "Design tokens for reusable UI components. Values may reference color tokens (theme.tokens.*) or scale tokens (theme.scale.*) by dot-notation path, or be raw numbers (pixel values).",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/componentNode"
  },
  "$defs": {
    "tokenRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "A dot-notation reference to a scale token such as space.md or radius.sm"
    },
    "scalarOrRef": {
      "oneOf": [
        { "$ref": "#/$defs/tokenRef" },
        { "type": "number" },
        { "type": "string" }
      ]
    },
    "componentNode": {
      "oneOf": [
        { "$ref": "#/$defs/scalarOrRef" },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/componentNode"
          }
        }
      ]
    }
  }
}
