{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/references.schema.json",
  "title": "Third-Party Reference Registry",
  "description": "Tracks external icon packs and UI libraries referenced for inspiration or optional compatibility mapping in the Themes project.",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/referenceSource"
      }
    }
  },
  "$defs": {
    "referenceSource": {
      "type": "object",
      "required": ["id", "name", "type", "usage", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Stable machine-readable identifier for this reference source"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable display name"
        },
        "type": {
          "type": "string",
          "enum": ["icon-pack", "ui-system", "ui-library", "design-tokens", "specification"],
          "description": "Category of the reference source"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Primary URL for the project"
        },
        "license": {
          "type": "string",
          "description": "Claimed SPDX license identifier or description. Treat as unverified until status is 'approved'."
        },
        "status": {
          "type": "string",
          "enum": [
            "reference_only",
            "license_verification_pending",
            "approved",
            "excluded"
          ],
          "description": "Current verification status. 'reference_only' means no code/assets are directly embedded."
        },
        "usage": {
          "type": "string",
          "minLength": 1,
          "description": "Brief description of how this reference is used in the project"
        },
        "notes": {
          "type": "string",
          "description": "Additional context, verification notes, or restrictions"
        }
      }
    }
  }
}
