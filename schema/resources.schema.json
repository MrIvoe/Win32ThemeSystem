{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrIvoe/Themes/schema/resources.schema.json",
  "title": "UI Resource Catalog",
  "description": "Selectable UI resources for a theme (icon packs, button styles, control presets).",
  "type": "object",
  "required": ["meta", "ui"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["themeId", "version"],
      "additionalProperties": false,
      "properties": {
        "themeId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "ui": {
      "type": "object",
      "required": ["icons", "buttons"],
      "additionalProperties": false,
      "properties": {
        "icons": {
          "type": "object",
          "required": ["defaultPack", "availablePacks"],
          "additionalProperties": false,
          "properties": {
            "defaultPack": {
              "type": "string",
              "minLength": 1
            },
            "availablePacks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "buttons": {
          "type": "object",
          "required": ["defaultStyle", "families", "styles"],
          "additionalProperties": false,
          "properties": {
            "defaultStyle": {
              "type": "string",
              "minLength": 1
            },
            "families": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "$ref": "#/$defs/buttonFamily"
              }
            },
            "styles": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "$ref": "#/$defs/buttonStyle"
              }
            }
          }
        },
        "controls": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "buttonFamily": {
      "type": "object",
      "required": ["defaultStyle", "styles"],
      "additionalProperties": false,
      "properties": {
        "defaultStyle": {
          "type": "string",
          "minLength": 1
        },
        "styles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "buttonStyle": {
      "type": "object",
      "required": ["label", "componentRef"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "componentRef": {
          "type": "string",
          "pattern": "^button\\.[a-z][a-zA-Z0-9_]*$"
        },
        "iconPackOverride": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
