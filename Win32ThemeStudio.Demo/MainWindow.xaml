<Window x:Class="Win32ThemeStudio.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Win32 Theme Studio"
        Height="760"
        Width="1180"
        MinHeight="650"
        MinWidth="980">
    <DockPanel Background="{DynamicResource Brush.Background}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Project">
                <MenuItem Header="New Theme Variant" />
                <MenuItem Header="Export Preview" />
                <Separator />
                <MenuItem Header="Exit" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Tokens" />
                <MenuItem Header="Preview Grid" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About Theme Studio" />
            </MenuItem>
        </Menu>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Theme Composer"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Text="Runtime switchable palettes for Win32-style WPF apps"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Margin="0,0,0,14" />

                    <TextBlock Text="Select Theme" FontWeight="SemiBold" />
                    <ComboBox x:Name="ThemeComboBox"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="ThemeComboBox_SelectionChanged"
                              Margin="0,6,0,14"
                              ToolTip="Switches the active palette dictionary in real time." />

                    <CheckBox x:Name="TransparentToggle"
                              Content="Use transparent background layer"
                              Margin="0,0,0,10"
                              Checked="TransparentToggle_Changed"
                              Unchecked="TransparentToggle_Changed" />

                    <TextBlock Text="Window Opacity" FontWeight="SemiBold" />
                    <Slider x:Name="OpacitySlider"
                            Minimum="0.65"
                            Maximum="1.0"
                            Value="0.94"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            Margin="0,6,0,6"
                            ValueChanged="OpacitySlider_ValueChanged" />

                    <TextBlock x:Name="OpacityLabel"
                               Text="94%"
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Accent Actions" FontWeight="SemiBold" Margin="0,2,0,6" />
                    <WrapPanel>
                        <Button Content="Primary"
                            Style="{StaticResource AccentButton}"
                            ToolTip="Standard primary action" />
                        <Button Content="Secondary" Background="{DynamicResource Brush.SurfaceAlt}" />
                        <Button Content="Warn"
                            Style="{StaticResource WarningButton}" />
                    </WrapPanel>

                    <TextBlock Text="Inputs" FontWeight="SemiBold" Margin="0,10,0,4" />
                    <TextBox Text="Token name: AccentColor" />
                    <TextBox Text="Description: High contrast call-to-action color." />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Live Preview"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Buttons, cards, menu and helper text react to palette brush tokens."
                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Surface A" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock Text="This panel uses Surface and Border brushes from the selected palette."
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           Margin="0,4,0,8" />

                                <WrapPanel>
                                    <Button Content="Save Theme" Style="{StaticResource AccentButton}" />
                                    <Button Content="Publish" Style="{StaticResource SuccessButton}" />
                                    <Button Content="Delete" Style="{StaticResource DangerButton}" />
                                </WrapPanel>

                                <TextBlock Text="Tooltip demo"
                                           Margin="0,10,0,4"
                                           ToolTip="The tooltip style is also themed with palette keys." />
                                <ProgressBar Height="14" Value="72" Margin="0,0,0,6" />
                                <ProgressBar Height="14" Value="40" Foreground="{DynamicResource Brush.Success}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Theme Tokens" FontWeight="SemiBold" FontSize="16" />
                                <ListBox Margin="0,8,0,0">
                                    <ListBoxItem>Brush.Background</ListBoxItem>
                                    <ListBoxItem>Brush.Surface</ListBoxItem>
                                    <ListBoxItem>Brush.WindowGlass</ListBoxItem>
                                    <ListBoxItem>Brush.Accent</ListBoxItem>
                                    <ListBoxItem>Brush.MenuBackground</ListBoxItem>
                                    <ListBoxItem>Brush.TooltipBackground</ListBoxItem>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
